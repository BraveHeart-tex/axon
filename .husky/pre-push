#!/usr/bin/env sh

current_branch=$(git symbolic-ref --short HEAD 2>/dev/null || echo "")
build_branch="${BUILD_BRANCH:-main}"

if [ "$current_branch" != "$build_branch" ]; then
  echo "ℹ️  Pushing to ${current_branch:-detached HEAD} - skipping build"
  exit 0
fi

repo_root=$(git rev-parse --show-toplevel) || exit 0
git_dir=$(git rev-parse --git-dir) || exit 0
log="$git_dir/async-build.log"

echo "🚀 Pushing to $current_branch - build will start after push (see $log)."

# Detach the build so it runs after the push instead of blocking commit/push.
(
  sleep 1
  cd "$repo_root" || exit 0

  echo "⏳ [$(date '+%H:%M:%S')] Build started." | tee "$log"

  if yarn build >>"$log" 2>&1; then
    echo "✅ [$(date '+%H:%M:%S')] Build succeeded." | tee -a "$log"
  else
    status=$?
    echo "❌ [$(date '+%H:%M:%S')] Build failed (exit $status). See $log." | tee -a "$log"
  fi
) &

exit 0
